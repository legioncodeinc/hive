{
  "name": "@legioncodeinc/hive",
  "version": "0.8.0",
  "description": "Hive portal daemon",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legioncodeinc/hive.git"
  },
  "//publishConfig": "PRD-001c: minimum fix needed for a valid scoped-package publish, mirroring honeycomb/doctor. `access: public` is required because scoped packages default to restricted; `provenance` pairs with release.yaml's `id-token: write` OIDC identity.",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist/cli.js",
  "bin": {
    "hive": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets/styles.css",
    "assets/tokens",
    "assets/logos",
    "assets/brand"
  ],
  "scripts": {
    "build": "tsc && node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js start",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "hono": "^4.12.27",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
